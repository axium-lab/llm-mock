# All variables are OPTIONAL — llm-mock works out of the box without a .env file.
# Copy to .env only if you want to override the defaults (Bun loads it automatically).

# Port to listen on (PORT is also accepted). Default: 3000
LLM_MOCK_PORT=3000

# Path to the JSON array of valid API keys. Default: api-keys.json
LLM_MOCK_API_KEYS_FILE=api-keys.json
